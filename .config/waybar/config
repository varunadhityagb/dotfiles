{
    "layer": "top",
    "spacing": 0,
    "position": "top",
    "reload_style_on_change": true,
    "modules-left": ["group/system", "group/music"],
    "modules-center": ["hyprland/workspaces", ],
    "modules-right": ["tray", "custom/updates", "battery", "clock"],

    "image#album-art": {
        "exec": "/home/varunadhityagb/dotfiles/.config/hypr/scripts/album_art.sh",
        "size": 28,
        "interval": 5,
    },

    "clock": {
        "format": "{:%a %b %d %R %p}",
        "tooltip": true,
        "tooltip-format": "{tz_list}",
        "timezones": [
                "Asia/Kolkata",
                "Etc/UTC",
                "America/New_York",
                "America/Montevideo",
                "America/Los_Angeles"
            ],
        "on-click": "~/dotfiles/.config/waybar/scripts/calendar.sh"
    },

    "network": {
        "format-wifi": "´çź ",
        "format-ethernet": "´âü ",
        "format-disconnected": "ˇ▒Ťů ",
        "format-disabled": "ˇ░ľ¬ ",
        "on-click": "~/dotfiles/.config/rofi/wifi.sh",
        "tooltip-format-wifi": "{essid} {signalStrength}% {frequency} GHz\n {ipaddr}/{cidr} \n {netmask}",
    },

    "hyprland/workspaces": {
        "on-scroll-up": "hyprctl dispatch workspace r-1",
        "on-scroll-down": "hyprctl dispatch workspace r+1",
        "on-click": "activate",
        "active-only": false,
        "all-outputs": false,
        "format": "{icon}",
        "format-icons": {
            "active": "´äĹ",
            "default": "´äĹ",
            "empty": "´äĹ"
            },
        "persistent-workspaces": {
            "*": [1,2,3,4,5]
        }
    },

    "hyprland/window": {
        "format": "{}",
        "rewrite": {
            "(.*) - Brave": "$1",
            "web.whatsapp.com" : "WhatsApp Web"
        },
        "separate-outputs": true
    },

    "custom/exit": {
        "format": "´ÇĹ",
        "on-click": "~/dotfiles/rofi/powermenu.sh",
        "tooltip-format": "Power Menu"
    },

    "custom/updates": {
        "format": "´ć▓   {}",
        "escape": true,
        "return-type": "json",
        "exec": "~/.config/hypr/scripts/updates.sh",
        "interval": 1800,
        "signal": 8,
        "on-click": "~/.config/hypr/scripts/update-menu.sh",
        "on-click-right": "pkill -SIGRTMIN+8 waybar",
    },

    "tray": {
        "spacing": 10,
        "show-passive-items": true,
        "icon-size": 21
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-icons": ["´ëä ", "´ëâ ", "´ëé ", "´ëü ", "´ëÇ "],
        "on-click": "~/dotfiles/.config/waybar/scripts/battery.sh",
    },

    "pulseaudio": {
        "scroll-step": 1,
        "format": "{icon}",
        "format-bluetooth": "{icon}",
        "format-bluetooth-muted": "´ĹŽ ",
        "format-muted": "´ĹŽ ",
        "format-icons": {
        "headphone": "´Çą ",
        "default": ["´ÇŽ ", "´ÇĘ ", "´ÇĘ "]
        },
        "on-click": "~/dotfiles/.config/waybar/scripts/volume.sh"
    },
    "bluetooth": {
        "format-on": "ˇ░é»",
        "format-off": "ˇ░é▓",
        "format-connected": "ˇ░őő",
        "tooltip-format-connected": "Battery : {device_battery_percentage}%",
        "on-click-right": "bluetoothctl power $(bluetoothctl show | grep -i \"Powered\" | awk '{print $2}' | xargs -I {} sh -c 'if [ \"$1\" = \"yes\" ]; then echo \"off\"; else echo \"on\"; fi' sh {})",
        "on-click": "~/dotfiles/.config/waybar/scripts/bluetooth.sh"
    },

    "custom/dnd": {
        "format": "{}",
        "exec": "swaync-client --get-dnd | grep -q true && echo '{\"text\":\"ˇ░éŤ\",\"tooltip\":\"DND On\"}' || echo '{\"text\":\"ˇ░é×\",\"tooltip\":\"DND Off\"}'",
        "return-type": "json",
        "on-click": "swaync-client -t",
        "on-click-right": "~/dotfiles/.config/hypr/scripts/dnd-toggle.sh",
        "signal": 10,
        "tooltip": true
    },

    "group/music": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 600,
            "transition-to-left": true,
            "click-to-reveal": true
        },
        "modules": ["mpris", "image#album-art" ],
    },

    "group/system": {
        "orientation": "horizontal",
        "modules": ["network",  "pulseaudio", "bluetooth", "hyprland/submap"],
    },

    "power-profiles-daemon": {
      "format": "{icon}",
      "tooltip-format": "Power profile: {profile}",
      "tooltip": true,
      "format-icons": {
        "default": "´âž",
        "performance": "´âž",
        "balanced": "ˇ░ÜÇ",
        "power-saver": "´üČ"
      }
    },

    "mpris": {
        "format": "{title}",
        "format-paused": "",
        "tooltip-format": "{player}\n{artist}\n{album}\n{title}",
        "ignored-players": ["firefox", "brave"]
    },

    "hyprland/submap": {
        "format": "ˇ░ś│   {}",
        "tooltip": false
    },

}
