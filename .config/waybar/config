{
    "layer": "top",
    "spacing": 0,
    "position": "top",
    "reload_style_on_change": true,
    "margin": "5 5",
    "modules-left": ["hyprland/workspaces", "custom/hyprland-windows", "hyprland/submap"],
    "modules-center": ["group/music"],
    "modules-right": ["tray", "custom/updates", "group/system", "clock"],

    "image#album-art": {
        "exec": "/home/varunadhityagb/dotfiles/.config/hypr/scripts/album_art.sh",
        "size": 28,
        "interval": 5,
    },

    "clock": {
        "format": "{:%a %b %d \n  %R %p}",
        "tooltip": true,
        "tooltip-format": "{tz_list}",
        "timezones": [
                "Asia/Kolkata",
                "Etc/UTC",
                "America/New_York",
                "America/Montevideo",
                "America/Los_Angeles"
            ],
        "on-click": "~/dotfiles/.config/waybar/scripts/calendar.sh"
    },

    "network": {
        "format-wifi": "’ć½ ",
        "format-ethernet": "’āü ",
        "format-disconnected": "¾▒øģ ",
        "format-disabled": "¾░¢¬ ",
        "on-click": "~/dotfiles/.config/rofi/wifi.sh",
        "tooltip-format-wifi": "{essid} {signalStrength}% {frequency} GHz\n {ipaddr}/{cidr} \n {netmask}",
    },

    "hyprland/workspaces": {
        "on-scroll-up": "hyprctl dispatch workspace r-1",
        "on-scroll-down": "hyprctl dispatch workspace r+1",
        "on-click": "activate",
        "active-only": false,
        "all-outputs": false,
        "format": "{icon}",
        "format-icons": {
            "active": "’äæ",
            "default": "’äæ",
            "empty": "’äæ"
            },
        "persistent-workspaces": {
            "*": [1,2,3,4,5]
        },
        "format-icons": {
            "1": "Code",
            "2": "Documents",
            "3": "Browser",
            "4": "Messages",
            "5": "Media"
        }
    },

    "hyprland/window": {
        "format": "{}",
        "rewrite": {
            "(.*) - Brave": "$1",
            "web.whatsapp.com" : "WhatsApp Web"
        },
        "separate-outputs": true
    },

    "custom/exit": {
        "format": "’Ćæ",
        "on-click": "~/dotfiles/rofi/powermenu.sh",
        "tooltip-format": "Power Menu"
    },

    "custom/updates": {
        "format": "’å▓   {}",
        "escape": true,
        "return-type": "json",
        "exec": "~/.config/hypr/scripts/updates.sh",
        "interval": 1800,
        "signal": 8,
        "on-click": "~/.config/hypr/scripts/update-menu.sh",
        "on-click-right": "pkill -SIGRTMIN+8 waybar",
    },

    "tray": {
        "spacing": 10,
        "show-passive-items": true,
        "icon-size": 21
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-icons": ["’ēä ", "’ēā ", "’ēé ", "’ēü ", "’ēĆ "],
        "on-click": "~/dotfiles/.config/waybar/scripts/battery.sh",
    },

    "pulseaudio": {
        "scroll-step": 1,
        "format": "{icon}",
        "format-bluetooth": "{icon}",
        "format-bluetooth-muted": "’æ” ",
        "format-muted": "’æ” ",
        "format-icons": {
        "headphone": "’Ćź ",
        "default": ["’Ć” ", "’Ć© ", "’Ć© "]
        },
        "on-click": "~/dotfiles/.config/waybar/scripts/volume.sh"
    },
    "bluetooth": {
        "format-on": "¾░é»",
        "format-off": "¾░é▓",
        "format-connected": "¾░ŗŗ   {device_battery_percentage}%",
        "on-click-right": "bluetoothctl power $(bluetoothctl show | grep -i \"Powered\" | awk '{print $2}' | xargs -I {} sh -c 'if [ \"$1\" = \"yes\" ]; then echo \"off\"; else echo \"on\"; fi' sh {})",
        "on-click": "~/dotfiles/.config/waybar/scripts/bluetooth.sh"
    },

    "custom/dnd": {
        "format": "{}",
        "exec": "swaync-client --get-dnd | grep -q true && echo '{\"text\":\"¾░éø\",\"tooltip\":\"DND On\"}' || echo '{\"text\":\"¾░é×\",\"tooltip\":\"DND Off\"}'",
        "return-type": "json",
        "on-click": "swaync-client -t",
        "on-click-right": "~/dotfiles/.config/hypr/scripts/dnd-toggle.sh",
        "signal": 10,
        "tooltip": true
    },

    "group/music": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 600,
            "transition-to-left": true,
        },
        "modules": ["cffi/nowplaying"],
    },

    "group/system": {
        "orientation": "horizontal",
        "modules": ["network",  "pulseaudio", "bluetooth", "battery"],
    },

    "power-profiles-daemon": {
      "format": "{icon}",
      "tooltip-format": "Power profile: {profile}",
      "tooltip": true,
      "format-icons": {
        "default": "’ā¦",
        "performance": "’ā¦",
        "balanced": "¾░ÜĆ",
        "power-saver": "’ü¼"
      }
    },

    "mpris": {
        "format": "{title}",
        "format-paused": "",
        "tooltip-format": "{player}\n{artist}\n{album}\n{title}",
        "ignored-players": ["firefox", "brave"]
    },

    "hyprland/submap": {
        "format": "¾░ś│   {}",
        "tooltip": false
    },

    "custom/hyprland-windows": {
        "exec": "~/dotfiles/.config/hypr/scripts/hyprland-windows",
        "return-type": "json",
        "signal": 8,
        "markup": "pango"
    },

    "cffi/lyrics": {
        "module_path": "/home/varunadhityagb/Syncthing/waylyrics/build/waylyrics.so"
    },

    "cffi/nowplaying": {
        "module_path": "/home/varunadhityagb/Syncthing/nowplaying/build/libnowplaying.so",
        "on-click":        "",
        "on-click-middle": "",
        "on-click-right":  ""
    }

}
